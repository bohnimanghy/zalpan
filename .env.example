# ── Contact form (Resend) ────────────────────────────────
# Create a key at https://resend.com/api-keys
RESEND_API_KEY=
# Where enquiries are delivered (defaults to hello@bohniman.com)
CONTACT_TO_EMAIL=hello@bohniman.com
# Verified sender. Until your domain is verified in Resend you can use
# "Bohniman Site <onboarding@resend.dev>"
CONTACT_FROM_EMAIL=Bohniman Site <onboarding@resend.dev>

# ── Admin (blog publisher) ───────────────────────────────
# Password to sign in at /admin
ADMIN_PASSWORD=
# Optional extra secret used to sign the session cookie (any random string)
ADMIN_SESSION_SECRET=

# ── GitHub (git-backed publishing) ───────────────────────
# Fine-grained PAT with "Contents: Read and write" on this repo
GITHUB_TOKEN=
# owner/repo, e.g. bohniman/bohniman.ai
GITHUB_REPO=
# Branch to commit posts to (Vercel deploys from this)
GITHUB_BRANCH=main
